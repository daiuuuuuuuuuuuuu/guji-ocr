# 复制此文件为 .env，然后填入你的 API Key
# cp .env.example .env

# DashScope API Key（阿里云百炼，用于 agent_qw OCR 识别）
GUJI_LLM_API_KEY=sk-your-dashscope-key-here

# DeepSeek API Key（用于 agent_verify 页序重排）
GUJI_VERIFY_API_KEY=sk-your-deepseek-key-here

# DeepSeek API Key（用于 agent_c 错别字纠正，可以和上面同一个）
GUJI_CORRECT_API_KEY=sk-your-deepseek-key-here
